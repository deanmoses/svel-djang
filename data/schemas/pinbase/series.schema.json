{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/series.schema.json",
  "title": "Pinbase Series",
  "description": "Frontmatter for a Pinbase-authored series record",
  "type": "object",
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 },
    "credit_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "person_slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "role": { "type": "string", "minLength": 1 }
        },
        "required": ["person_slug", "role"],
        "additionalProperties": false
      },
      "default": []
    }
  },
  "required": ["slug", "name"],
  "additionalProperties": false
}
