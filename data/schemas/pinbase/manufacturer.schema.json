{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/manufacturer.schema.json",
  "title": "Pinbase Manufacturer",
  "description": "Frontmatter for a Pinbase-authored manufacturer record",
  "type": "object",
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    }
  },
  "required": ["slug", "name"],
  "additionalProperties": false
}
