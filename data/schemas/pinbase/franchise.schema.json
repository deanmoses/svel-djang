{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pinbase/franchise.schema.json",
  "title": "Pinbase Franchise",
  "description": "Frontmatter for a Pinbase-authored franchise record",
  "type": "object",
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 }
  },
  "required": ["slug", "name"],
  "additionalProperties": false
}
