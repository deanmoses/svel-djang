{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "titles.schema.json",
  "title": "Titles",
  "description": "Game titles that may have multiple models/editions",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "name": { "type": "string", "minLength": 1 },
      "opdb_group_id": {
        "type": "string",
        "description": "OPDB group identifier linking all models of this title"
      },
      "franchise_slug": {
        "type": "string",
        "description": "References a slug in franchises.json"
      },
      "series_slug": {
        "type": "string",
        "description": "References a slug in series.json"
      },
      "split_from_opdb_group": {
        "type": "string",
        "description": "OPDB group ID that this title was split from; prevents the OPDB ingester from creating the combined group title"
      },
      "abbreviations": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "uniqueItems": true
      }
    },
    "required": ["slug", "name"],
    "additionalProperties": false
  }
}
